# ── Folders to ignore (comma-separated names, matched at any depth) ───────────
# These folder names are skipped in ALL vaults. Dot-prefixed names like .obsidian
# work here — no need for a separate rule.
IGNORE_FOLDERS=.obsidian,.trash

#
# ── Files in past NEW_FILES_DAYS are starred  in tree view ────────────────────
NEW_FILES_DAYS=30

# ── Vault Pair 1 ──────────────────────────────────────────────────────────────
# Name used in logs and the browser title bar
PAIR_1_NAME=my-vault

# Absolute path on the HOST machine to the Obsidian vault folder
PAIR_1_INPUT=/home/youruser/Documents/Obsidian/MyVault

# Absolute path on the HOST machine where HTML output will be written
PAIR_1_OUTPUT=/home/youruser/obsidian-viewer-output/my-vault

# Port on the host that nginx will serve this site on
PAIR_1_PORT=8081

# ── Vault Pair 2 (optional — add as many pairs as needed) ─────────────────────
# PAIR_2_NAME=work-notes
# PAIR_2_INPUT=/home/youruser/Documents/Obsidian/WorkNotes
# PAIR_2_OUTPUT=/home/youruser/obsidian-viewer-output/work-notes
# PAIR_2_PORT=8082

# ── miraview-server (read tracking + auth) ────────────────────────────────────
# Internal port the miraview-server listens on (not exposed to host; nginx proxies to it)
API_INTERNAL_PORT=3001

# Comma-separated user:password pairs for simple login.
# Add as many users as needed. Passwords are stored plaintext — keep this file private.
# Example: AUTH_USERS=alice:hunter2,bob:correcthorse
AUTH_USERS=admin:changeme
